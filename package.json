{
  "name": "app",
  "private": true,
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.config.js",
    "build:dev": "webpack --config webpack.config.js",
    "build:css": "sass ./app/assets/stylesheets/application.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "e2e": "npx playwright test",
    "e2e:headed": "npx playwright test --headed",
    "e2e:ui": "npx playwright test --ui",
    "e2e:report": "node scripts/generate-report.js",
    "e2e:full": "npx playwright test && node scripts/generate-report.js",
    "e2e:show": "npx playwright show-report e2e/reports/html",
    "record": "node scripts/record-session.js",
    "record:report": "node scripts/record-session.js && node scripts/generate-report.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "mini-css-extract-plugin": "^2.10.2",
    "sass-loader": "^16.0.7",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "chartkick": "^5.0.1",
    "sass": "^1.99.0"
  }
}
