<% content_for(:title, "Get Started — Job Agent") %>

<div class="onboarding">
  <%# ── Progress Bar ── %>
  <% step_labels = { "resume" => "Upload Resume", "profile" => "Your Profile", "source" => "Job Board", "complete" => "Done!" } %>
  <% steps = %w[resume profile source complete] %>
  <div class="onboarding__progress mb-4">
    <div class="d-flex justify-content-between">
      <% steps.each_with_index do |s, i| %>
        <% current_idx = steps.index(@step) || 0 %>
        <div class="onboarding__step <%= 'onboarding__step--active' if s == @step %> <%= 'onboarding__step--done' if i < current_idx %>">
          <div class="onboarding__step-number"><%= i + 1 %></div>
          <div class="onboarding__step-label"><%= step_labels[s] %></div>
        </div>
        <% if i < steps.size - 1 %>
          <div class="onboarding__step-line <%= 'onboarding__step-line--done' if i < current_idx %>"></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# ── Step Content ── %>
  <div class="card onboarding__card">
    <div class="card-body p-4 p-md-5">

      <% if @step == "resume" %>
        <%# ── STEP 1: Resume Upload (Hero treatment) ── %>
        <div class="text-center mb-4">
          <h2 class="mb-2">Let's start with your resume</h2>
          <p class="text-muted">Upload your resume and we'll build your profile automatically.</p>
        </div>

        <%= form_with url: update_step_onboarding_path, method: :post, multipart: true do |f| %>
          <input type="hidden" name="step" value="resume">
          <div class="onboarding__upload-zone mb-4">
            <div class="onboarding__upload-zone-inner">
              <div class="onboarding__upload-zone-icon">&#x1F4C4;</div>
              <p class="onboarding__upload-zone-text fw-semibold mb-1">Drag and drop your resume here</p>
              <p class="text-muted small mb-3">or click to browse files</p>
              <input type="file" name="source_document" class="onboarding__upload-zone-input" accept=".pdf,.txt,.rtf,.jpg,.jpeg,.png,.webp">
              <div class="d-flex justify-content-center gap-3 mt-2">
                <span class="badge bg-light text-dark border">PDF</span>
                <span class="badge bg-light text-dark border">TXT</span>
                <span class="badge bg-light text-dark border">JPG/PNG</span>
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-center">
            <a href="<%= skip_step_onboarding_path(step: 'resume') %>" class="text-muted small text-decoration-none" data-turbo-method="post">I'll do this later</a>
            <button type="submit" class="btn btn-primary px-4">Upload &amp; Continue</button>
          </div>
        <% end %>

        <div class="text-center my-3">
          <span class="text-muted small">or</span>
        </div>

        <%= form_with url: update_step_onboarding_path, method: :post do |f| %>
          <input type="hidden" name="step" value="resume">
          <div class="input-group">
            <span class="input-group-text">&#x1F517;</span>
            <input type="url" name="linkedin_url" class="form-control" placeholder="https://linkedin.com/in/yourname">
            <button type="submit" class="btn btn-outline-primary">Import from LinkedIn</button>
          </div>
          <div class="form-text text-center">Paste your LinkedIn profile URL to auto-fill your profile</div>
        <% end %>

      <% elsif @step == "profile" %>
        <%# ── STEP 2: Profile (Pre-filled from resume) ── %>
        <h2 class="mb-1">Review your profile</h2>
        <% if @profile.source_document.attached? %>
          <p class="text-muted mb-4">We extracted this from your resume. Review and correct anything that looks off.</p>
        <% else %>
          <p class="text-muted mb-4">Tell us about yourself so we can find the right jobs.</p>
        <% end %>

        <%= form_with url: update_step_onboarding_path, method: :post do |f| %>
          <input type="hidden" name="step" value="profile">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">First Name</label>
              <input type="text" name="profile[first_name]" class="form-control" placeholder="John"
                     value="<%= @profile.contact_field('first_name') %>" autofocus>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Last Name</label>
              <input type="text" name="profile[surname]" class="form-control" placeholder="Doe"
                     value="<%= @profile.contact_field('surname') %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Email</label>
              <input type="email" name="profile[email]" class="form-control" placeholder="you@example.com"
                     value="<%= @profile.contact_field('email').presence || current_user.email %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Phone</label>
              <input type="text" name="profile[phone]" class="form-control" placeholder="+1 555-0123"
                     value="<%= @profile.contact_field('phone') %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">City</label>
              <input type="text" name="profile[city]" class="form-control" placeholder="New York"
                     value="<%= @profile.contact_field('city') %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Country</label>
              <input type="text" name="profile[country]" class="form-control" placeholder="United States"
                     value="<%= @profile.contact_field('country') %>">
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Professional Headline</label>
              <input type="text" name="profile[headline]" class="form-control" placeholder="Senior Ruby on Rails Developer"
                     value="<%= @profile.headline %>">
            </div>
          </div>
          <div class="d-flex justify-content-between align-items-center mt-4">
            <a href="<%= skip_step_onboarding_path(step: 'profile') %>" class="text-muted small text-decoration-none" data-turbo-method="post">Skip for now</a>
            <button type="submit" class="btn btn-primary px-4">Save &amp; Continue</button>
          </div>
        <% end %>

      <% elsif @step == "source" %>
        <%# ── STEP 3: Job Board + Optional Search Criteria ── %>
        <h2 class="mb-1">Where should we look for jobs?</h2>
        <p class="text-muted mb-4">Pick a job board. You can add more from your dashboard later.</p>

        <%= form_with url: update_step_onboarding_path, method: :post do |f| %>
          <input type="hidden" name="step" value="source">

          <%# ── Platform Cards ── %>
          <div class="row g-3 mb-4">
            <% platforms = { "linkedin" => ["&#x1F4BC;", "LinkedIn", "Professional network jobs"], "indeed" => ["&#x1F50D;", "Indeed", "Largest job board"], "naukri" => ["&#x1F4CB;", "Naukri", "India's top job site"] } %>
            <% platforms.each do |key, (icon, label, desc)| %>
              <div class="col-md-4">
                <label class="onboarding__platform-card">
                  <input type="radio" name="job_source[platform]" value="<%= key %>" class="d-none" <%= 'checked' if key == 'linkedin' %>>
                  <div class="onboarding__platform-card-inner">
                    <div class="onboarding__platform-card-icon"><%= raw icon %></div>
                    <div class="fw-semibold"><%= label %></div>
                    <div class="text-muted small"><%= desc %></div>
                  </div>
                </label>
              </div>
            <% end %>
          </div>

          <%# ── Optional: Search Criteria ── %>
          <div class="border-top pt-3 mt-2">
            <p class="fw-semibold mb-2 small text-muted text-uppercase">Optional: What are you looking for?</p>
            <div class="row g-3">
              <div class="col-md-6">
                <input type="text" name="criteria[keywords]" class="form-control form-control-sm"
                       placeholder="e.g. Ruby on Rails Developer"
                       value="<%= @profile.headline %>">
              </div>
              <div class="col-md-6">
                <input type="text" name="criteria[location]" class="form-control form-control-sm"
                       placeholder="e.g. New York, NY"
                       value="<%= @profile.contact_field('city') %>">
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-center mt-4">
            <a href="<%= skip_step_onboarding_path(step: 'source') %>" class="text-muted small text-decoration-none" data-turbo-method="post">Skip for now</a>
            <button type="submit" class="btn btn-primary px-4">Continue</button>
          </div>
        <% end %>

      <% elsif @step == "complete" %>
        <%# ── STEP 4: Done ── %>
        <div class="text-center py-3">
          <div class="mb-3" style="font-size: 3.5rem;">&#x1F389;</div>
          <h2 class="mb-2">You're all set!</h2>
          <p class="text-muted mb-4">Your account is ready. We'll start finding jobs that match your profile.</p>
          <%= form_with url: update_step_onboarding_path, method: :post do %>
            <input type="hidden" name="step" value="complete">
            <button type="submit" class="btn btn-primary btn-lg px-5">Go to Dashboard &rarr;</button>
          <% end %>
        </div>

      <% end %>
    </div>
  </div>
</div>
