<% content_for(:title, "Page Not Found — Job Agent") %>

<div class="text-center">
  <div class="mb-3" style="font-size: 3rem;"><i class="bi bi-search"></i></div>
  <h2 class="mb-2">Page Not Found</h2>
  <p class="text-muted mb-4">The page you're looking for doesn't exist or has been moved.</p>
  <% if user_signed_in? %>
    <%= link_to "Go to Dashboard", dashboard_path, class: "btn btn-primary" %>
  <% else %>
    <%= link_to "Go Home", root_path, class: "btn btn-primary" %>
  <% end %>
</div>
