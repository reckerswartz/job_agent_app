<% content_for(:page_title, "Analytics") %>

<%= render "shared/page_header", title: "Analytics", subtitle: "Insights into your job search activity" %>

<div class="row g-4">
  <%# ── Listings Over Time ── %>
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Listings Over Time</h3></div>
      <div class="card-body">
        <%= line_chart @analytics.listings_over_time, label: "Job Listings", colors: ["#1E3A5F"] %>
      </div>
    </div>
  </div>

  <%# ── Match Score Distribution ── %>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Match Score Distribution</h3></div>
      <div class="card-body">
        <%= pie_chart @analytics.match_score_distribution, colors: ["#EF4444", "#F59E0B", "#10B981"] %>
      </div>
    </div>
  </div>

  <%# ── Applications by Status ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Applications by Status</h3></div>
      <div class="card-body">
        <%= bar_chart @analytics.applications_by_status, colors: ["#3B82F6"] %>
      </div>
    </div>
  </div>

  <%# ── Source Performance ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Listings by Source</h3></div>
      <div class="card-body">
        <%= column_chart @analytics.source_performance, colors: ["#4ECDC4"] %>
      </div>
    </div>
  </div>

  <%# ── Scan Activity ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Scan Activity</h3></div>
      <div class="card-body">
        <%= area_chart @analytics.scan_activity, label: "Scans", colors: ["#1E3A5F"] %>
      </div>
    </div>
  </div>

  <%# ── Top Companies ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Top Companies</h3></div>
      <div class="card-body">
        <%= bar_chart @analytics.top_companies, colors: ["#FF6B6B"] %>
      </div>
    </div>
  </div>
</div>
