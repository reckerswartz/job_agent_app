<% content_for(:page_title, "Analytics") %>

<%= render "shared/page_header", title: "Analytics", subtitle: "Insights into your job search activity" %>

<% if JobListing.for_user(current_user).none? %>
  <div class="empty-state text-center py-5">
    <div class="empty-state__icon mb-3" style="font-size: 2.5rem;"><i class="bi bi-graph-up"></i></div>
    <h3 class="empty-state__title">No analytics data yet</h3>
    <p class="text-muted">Analytics will populate as you add job sources, run scans, and apply to jobs.</p>
    <%= link_to "Set Up Job Sources", job_sources_path, class: "btn btn-primary" %>
  </div>
<% else %>
<div class="row g-4">
  <%# ── Listings Over Time ── %>
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Listings Over Time</h3></div>
      <div class="card-body">
        <%= line_chart @analytics.listings_over_time, label: "Job Listings", colors: ["#1E3A5F"] %>
      </div>
    </div>
  </div>

  <%# ── Match Score Distribution ── %>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Match Score Distribution</h3></div>
      <div class="card-body">
        <%= pie_chart @analytics.match_score_distribution, colors: ["#EF4444", "#F59E0B", "#10B981"] %>
      </div>
    </div>
  </div>

  <%# ── Applications by Status ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Applications by Status</h3></div>
      <div class="card-body">
        <%= bar_chart @analytics.applications_by_status, colors: ["#3B82F6"] %>
      </div>
    </div>
  </div>

  <%# ── Source Performance ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Listings by Source</h3></div>
      <div class="card-body">
        <%= column_chart @analytics.source_performance, colors: ["#4ECDC4"] %>
      </div>
    </div>
  </div>

  <%# ── Scan Activity ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Scan Activity</h3></div>
      <div class="card-body">
        <%= area_chart @analytics.scan_activity, label: "Scans", colors: ["#1E3A5F"] %>
      </div>
    </div>
  </div>

  <%# ── Top Companies ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Top Companies</h3></div>
      <div class="card-body">
        <%= bar_chart @analytics.top_companies, colors: ["#FF6B6B"] %>
      </div>
    </div>
  </div>

  <%# ── Salary Distribution ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Salary Distribution</h3></div>
      <div class="card-body">
        <%= bar_chart @analytics.salary_distribution, colors: ["#10B981"] %>
      </div>
    </div>
  </div>

  <%# ── Salary by Source ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Avg Salary by Source</h3></div>
      <div class="card-body">
        <%= column_chart @analytics.salary_by_source, prefix: "$", colors: ["#F59E0B"] %>
      </div>
    </div>
  </div>

  <%# ── Pipeline Stage Distribution ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Application Pipeline</h3></div>
      <div class="card-body">
        <%= pie_chart @analytics.pipeline_distribution, colors: ["#1E3A5F", "#3B82F6", "#F59E0B", "#10B981", "#10B981", "#EF4444", "#6c757d"] %>
      </div>
    </div>
  </div>

  <%# ── Scan Success Rate ── %>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-header__title mb-0">Scan Success Rate</h3></div>
      <div class="card-body text-center">
        <% sr = @analytics.scan_success_rate %>
        <div class="fw-bold" style="font-size: 3rem; color: <%= sr[:rate] >= 80 ? '#10B981' : (sr[:rate] >= 50 ? '#F59E0B' : '#EF4444') %>;">
          <%= sr[:rate] %>%
        </div>
        <div class="text-muted small"><%= sr[:completed] %> completed / <%= sr[:total] %> total scans</div>
        <% if sr[:failed] > 0 %>
          <div class="text-danger small mt-1"><%= sr[:failed] %> failed</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<% end %>
