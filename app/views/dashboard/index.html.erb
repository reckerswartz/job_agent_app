<% content_for(:page_title, "Dashboard") %>

<%= render "shared/page_header", title: "Dashboard" %>

<%# ── Stats Row ── %>
<% user_stats = [
  { value: @jobs_found, label: "Jobs Found", icon: "bi-search", color: "primary", link: job_listings_path },
  { value: @high_matches, label: "High Matches", icon: "bi-check-circle", color: "success", link: job_listings_path(min_match: 70) },
  { value: @applied, label: "Applied", icon: "bi-send", color: "info", link: job_listings_path(status: "applied") },
  { value: @pending_interventions, label: "Needs Attention", icon: "bi-exclamation-triangle", color: "warning", link: interventions_path }
] %>
<div class="row g-3 mb-4">
  <% user_stats.each do |s| %>
    <div class="col-sm-6 col-xl-3">
      <%= render "shared/stat_card", **s %>
    </div>
  <% end %>
</div>

<%# ── Main content: Table + Activity Feed ── %>
<div class="row g-3">
  <%# ── Job Listings Table ── %>
  <div class="col-xl-8">
    <div class="card dash-table-card">
      <div class="card-header">
        <h3 class="card-header__title mb-0">Recent Job Listings</h3>
        <%= link_to "View All", job_listings_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <% if @recent_listings.any? %>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Position</th>
                <th>Company</th>
                <th>Location</th>
                <th>Match</th>
                <th>Source</th>
                <th>Posted</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_listings.each do |listing| %>
                <tr>
                  <td><%= link_to listing.title, job_listing_path(listing), class: "fw-bold text-decoration-none" %></td>
                  <td><%= listing.company %></td>
                  <td><%= listing.location %></td>
                  <td>
                    <% if listing.match_score %>
                      <span class="match-score <%= listing.match_badge_class %>"><%= listing.match_score %>%</span>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td><span class="badge source-badge bg-<%= listing.job_source.platform_color %>"><%= listing.job_source.platform.capitalize %></span></td>
                  <td class="text-muted"><%= listing.posted_at ? time_ago_in_words(listing.posted_at) + " ago" : "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="card-body text-center py-4">
          <p class="text-muted mb-2">No job listings yet.</p>
          <%= link_to "Set up job sources to start scanning", job_sources_path, class: "btn btn-sm btn-outline-primary" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Activity Feed + Upcoming Interviews ── %>
  <div class="col-xl-4">
    <% if @upcoming_interviews.any? %>
      <div class="card mb-3">
        <div class="card-header">
          <h3 class="card-header__title mb-0">Upcoming Interviews</h3>
        </div>
        <div class="card-body p-0">
          <table class="table mb-0">
            <tbody>
              <% @upcoming_interviews.each do |interview| %>
                <tr>
                  <td class="small">
                    <div class="fw-bold"><%= interview.job_application.job_listing.company %></div>
                    <div class="text-muted" style="font-size: 0.7rem;"><%= interview.stage_label %> &middot; <%= interview.format&.humanize %></div>
                  </td>
                  <td class="text-end small text-muted">
                    <% if interview.scheduled_at %>
                      <%= interview.scheduled_at.strftime("%b %d, %I:%M%p") %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <div class="card activity-card">
      <div class="card-header">
        <h3 class="card-header__title mb-0">Recent Activity</h3>
        <%= link_to "View All", activity_logs_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <% if @recent_activity.any? %>
        <ul class="activity-feed">
          <% @recent_activity.each do |event| %>
            <li class="activity-feed__item">
              <% icon_class = { "search" => "bi-search", "match" => "bi-star-fill", "applied" => "bi-send", "alert" => "bi-exclamation-triangle" }[event[:icon]] || "bi-exclamation-triangle" %>
              <div class="activity-feed__icon activity-feed__icon--<%= event[:icon] %>"><i class="bi <%= icon_class %>"></i></div>
              <div class="activity-feed__body">
                <p class="activity-feed__text"><%= raw event[:text] %></p>
                <div class="activity-feed__time"><%= time_ago_in_words(event[:time]) %> ago</div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-center py-4">
          <p class="text-muted mb-0">No recent activity. Start by adding job sources and running a scan.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
