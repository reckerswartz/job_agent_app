<% content_for(:title, "Sign Up — Job Agent") %>

<h2 class="auth-title text-center mb-1">Create your account</h2>
<p class="auth-subtitle text-center mb-4">Start automating your job search</p>

<%= form_with(model: @user, url: sign_up_path, class: "auth-form") do |f| %>
  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <% @user.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :email_address, "Email", class: "form-label" %>
    <%= f.email_field :email_address, class: "form-control form-control-lg", placeholder: "you@example.com", required: true, autofocus: true %>
  </div>

  <div class="mb-3">
    <%= f.label :password, class: "form-label" %>
    <%= f.password_field :password, class: "form-control form-control-lg", placeholder: "Minimum 8 characters", required: true, minlength: 8 %>
  </div>

  <div class="mb-4">
    <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
    <%= f.password_field :password_confirmation, class: "form-control form-control-lg", placeholder: "Repeat your password", required: true %>
  </div>

  <div class="d-grid">
    <%= f.submit "Create Account", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>

<div class="auth-alt text-center mt-4">
  Already have an account? <%= link_to "Sign in", sign_in_path, class: "auth-alt__link" %>
</div>
