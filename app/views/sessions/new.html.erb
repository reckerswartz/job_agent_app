<% content_for(:title, "Sign In — Job Agent") %>

<h2 class="auth-title text-center mb-1">Welcome back</h2>
<p class="auth-subtitle text-center mb-4">Sign in to your account</p>

<%= form_with(url: sign_in_path, class: "auth-form") do |f| %>
  <div class="mb-3">
    <%= f.label :email_address, "Email", class: "form-label" %>
    <%= f.email_field :email_address, class: "form-control form-control-lg", placeholder: "you@example.com", required: true, autofocus: true %>
  </div>

  <div class="mb-4">
    <%= f.label :password, class: "form-label" %>
    <%= f.password_field :password, class: "form-control form-control-lg", placeholder: "Your password", required: true %>
  </div>

  <div class="d-grid">
    <%= f.submit "Sign In", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>

<div class="auth-alt text-center mt-4">
  Don't have an account? <%= link_to "Sign up", sign_up_path, class: "auth-alt__link" %>
</div>
