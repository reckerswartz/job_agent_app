<aside class="sidebar" data-sidebar-target="sidebar">
  <%= link_to root_path, class: "sidebar__brand" do %>
    <span class="sidebar__brand-icon">&#x1F4BC;</span>
    Job Agent
  <% end %>

  <ul class="sidebar__nav">
    <li class="sidebar__heading">Main</li>
    <li>
      <%= link_to dashboard_path, class: "sidebar__link #{current_page?(dashboard_path) ? 'sidebar__link--active' : ''}" do %>
        <span class="sidebar__link-icon">&#x1F4CA;</span> Dashboard
      <% end %>
    </li>
    <li>
      <%= link_to job_sources_path, class: "sidebar__link #{request.path.start_with?('/job_sources', '/job_search_criteria') ? 'sidebar__link--active' : ''}" do %>
        <span class="sidebar__link-icon">&#x1F50D;</span> Job Sources
      <% end %>
    </li>
    <li>
      <%= link_to job_listings_path, class: "sidebar__link #{request.path.start_with?('/job_listings') ? 'sidebar__link--active' : ''}" do %>
        <span class="sidebar__link-icon">&#x1F4CB;</span> Job Listings
      <% end %>
    </li>
    <li>
      <%= link_to job_applications_path, class: "sidebar__link #{request.path.start_with?('/job_applications') ? 'sidebar__link--active' : ''}" do %>
        <span class="sidebar__link-icon">&#x1F4E8;</span> Applications
      <% end %>
    </li>

    <li>
      <% pending_count = user_signed_in? ? current_user.interventions.pending.count : 0 %>
      <%= link_to interventions_path, class: "sidebar__link #{request.path.start_with?('/interventions') ? 'sidebar__link--active' : ''}" do %>
        <span class="sidebar__link-icon">&#x26A0;</span> Interventions
        <% if pending_count > 0 %>
          <span class="badge bg-warning text-dark ms-auto"><%= pending_count %></span>
        <% end %>
      <% end %>
    </li>

    <li class="sidebar__heading">Settings</li>
    <li>
      <%= link_to profile_path, class: "sidebar__link #{current_page?(profile_path) || current_page?(edit_profile_path) ? 'sidebar__link--active' : ''}" do %>
        <span class="sidebar__link-icon">&#x1F464;</span> Profile
      <% end %>
    </li>
    <li>
      <%= link_to edit_settings_path, class: "sidebar__link #{current_page?(edit_settings_path) ? 'sidebar__link--active' : ''}" do %>
        <span class="sidebar__link-icon">&#x2699;</span> Settings
      <% end %>
    </li>
  </ul>

  <div class="sidebar__footer">
    <% if user_signed_in? %>
      <div class="sidebar__user">
        <span class="sidebar__user-avatar"><%= current_user.initials %></span>
        <span class="sidebar__user-name"><%= current_user.display_name %></span>
      </div>
    <% end %>
  </div>
</aside>
