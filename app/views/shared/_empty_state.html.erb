<div class="card source-empty-card">
  <div class="card-body text-center py-5">
    <div class="source-empty-card__icon mb-3"><%= raw icon %></div>
    <h3><%= title %></h3>
    <p class="text-muted mb-3"><%= message %></p>
    <% if local_assigns[:cta_text] && local_assigns[:cta_path] %>
      <%= link_to cta_text, cta_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
