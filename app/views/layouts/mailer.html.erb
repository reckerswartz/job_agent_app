<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Agent</title>
  </head>
  <body style="margin: 0; padding: 0; background-color: #f4f6f9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; color: #1A1A2E; line-height: 1.6;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f6f9;">
      <tr>
        <td align="center" style="padding: 24px 16px;">
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%;">
            <%# ── Header ── %>
            <tr>
              <td style="background-color: #1E3A5F; padding: 20px 32px; border-radius: 8px 8px 0 0; text-align: center;">
                <span style="font-size: 24px; margin-right: 8px;">&#x1F4BC;</span>
                <span style="color: #ffffff; font-size: 20px; font-weight: 800; letter-spacing: -0.025em;">Job Agent</span>
              </td>
            </tr>
            <%# ── Body ── %>
            <tr>
              <td style="background-color: #ffffff; padding: 32px; border-left: 1px solid #e9ecef; border-right: 1px solid #e9ecef;">
                <%= yield %>
              </td>
            </tr>
            <%# ── Footer ── %>
            <tr>
              <td style="background-color: #f8f9fa; padding: 20px 32px; border-radius: 0 0 8px 8px; border: 1px solid #e9ecef; border-top: none; text-align: center; font-size: 12px; color: #6c757d;">
                <p style="margin: 0 0 8px;">
                  <a href="<%= edit_settings_url %>" style="color: #1E3A5F; text-decoration: none;">Manage notifications</a>
                  &nbsp;&middot;&nbsp;
                  <a href="<%= edit_settings_url %>" style="color: #1E3A5F; text-decoration: none;">Unsubscribe</a>
                </p>
                <p style="margin: 0; color: #adb5bd;">&copy; <%= Date.today.year %> Job Agent App</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
