<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dashboard — Job Agent" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Job Agent App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="page-dashboard" data-controller="sidebar shortcuts">
    <div class="dashboard-wrapper">
      <%# ── Sidebar ── %>
      <%= render "shared/dashboard/sidebar" %>

      <%# ── Overlay for mobile ── %>
      <div class="sidebar-overlay"
           data-sidebar-target="overlay"
           data-action="click->sidebar#close"></div>

      <%# ── Main content area ── %>
      <div class="dashboard-main">
        <%# ── Topbar ── %>
        <%= render "shared/dashboard/topbar" %>

        <%# ── Toast Notifications ── %>
        <div class="toast-container">
          <% if notice.present? %>
            <div class="toast-notification toast-notification--success" data-controller="toast">
              <span><%= notice %></span>
              <button type="button" class="btn-close btn-close-white btn-sm" data-action="click->toast#dismiss"></button>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="toast-notification toast-notification--danger" data-controller="toast">
              <span><%= alert %></span>
              <button type="button" class="btn-close btn-close-white btn-sm" data-action="click->toast#dismiss"></button>
            </div>
          <% end %>
        </div>

        <%# ── Page content ── %>
        <div class="dashboard-content">
          <%= yield %>
        </div>

        <%# ── Footer ── %>
        <div class="dashboard-footer">
          &copy; <%= Date.today.year %> Job Agent App
        </div>
      </div>
    </div>

    <%# ── Keyboard Shortcuts Help Modal ── %>
    <div class="shortcuts-modal" style="display:none;" data-shortcuts-target="modal">
      <div class="shortcuts-modal__backdrop" data-action="click->shortcuts#closeHelp"></div>
      <div class="shortcuts-modal__content">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h3 class="mb-0">Keyboard Shortcuts</h3>
          <button class="btn-close" data-action="click->shortcuts#closeHelp"></button>
        </div>
        <table class="table table-sm mb-0">
          <tbody>
            <tr><td><kbd>g</kbd> <kbd>d</kbd></td><td>Dashboard</td></tr>
            <tr><td><kbd>g</kbd> <kbd>s</kbd></td><td>Job Sources</td></tr>
            <tr><td><kbd>g</kbd> <kbd>l</kbd></td><td>Job Listings</td></tr>
            <tr><td><kbd>g</kbd> <kbd>a</kbd></td><td>Applications</td></tr>
            <tr><td><kbd>g</kbd> <kbd>p</kbd></td><td>Profile</td></tr>
            <tr><td><kbd>g</kbd> <kbd>i</kbd></td><td>Interventions</td></tr>
            <tr><td><kbd>g</kbd> <kbd>e</kbd></td><td>Settings</td></tr>
            <tr><td><kbd>?</kbd></td><td>Show this help</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
