<div class="home-page">
  <%# ── Hero Section ── %>
  <section class="hero">
    <h1 class="hero__title display-4">Find Your Next Role, Automatically</h1>
    <p class="hero__subtitle">
      Job Agent searches multiple job boards, extracts relevant listings,
      and ranks them against your profile &mdash; so you focus on applying, not searching.
    </p>
    <div class="hero__actions">
      <%= link_to "Get Started", dashboard_path, class: "btn btn-primary btn-lg px-4" %>
      <%= link_to "How It Works", "#features", class: "btn btn-outline-secondary btn-lg px-4" %>
    </div>
  </section>

  <%# ── Stats Bar ── %>
  <div class="stats-bar">
    <div class="row text-center">
      <div class="col-4">
        <div class="stats-bar__item">
          <div class="stats-bar__item-value">6+</div>
          <div class="stats-bar__item-label">Job Boards</div>
        </div>
      </div>
      <div class="col-4">
        <div class="stats-bar__item">
          <div class="stats-bar__item-value">24/7</div>
          <div class="stats-bar__item-label">Automated Search</div>
        </div>
      </div>
      <div class="col-4">
        <div class="stats-bar__item">
          <div class="stats-bar__item-value">Smart</div>
          <div class="stats-bar__item-label">Match Ranking</div>
        </div>
      </div>
    </div>
  </div>

  <%# ── Features Section ── %>
  <section id="features" class="features-section">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card feature-card h-100">
          <div class="card-body">
            <div class="feature-card__icon">&#x1F310;</div>
            <h5 class="card-title">Multi-Board Search</h5>
            <p class="card-text">Searches LinkedIn, Indeed, Glassdoor, and more in parallel using browser automation.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card feature-card h-100">
          <div class="card-body">
            <div class="feature-card__icon">&#x1F4CA;</div>
            <h5 class="card-title">Smart Ranking</h5>
            <p class="card-text">Scores every listing against your skills, location, salary expectations, and preferences.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card feature-card h-100">
          <div class="card-body">
            <div class="feature-card__icon">&#x26A1;</div>
            <h5 class="card-title">Background Jobs</h5>
            <p class="card-text">Solid Queue runs searches on a schedule so new matches are ready when you are.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
