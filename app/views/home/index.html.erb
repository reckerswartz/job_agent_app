<div id="home-page">
  <div class="px-4 py-5 my-5 text-center">
    <h1 class="display-5 fw-bold">Job Agent App</h1>
    <div class="col-lg-6 mx-auto">
      <p class="lead mb-4">Welcome to the Job Agent App. This application is powered by Rails&nbsp;8, Hotwire, and Solid&nbsp;Queue.</p>
      <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
        <%= link_to "Get Started", "#", class: "btn btn-primary btn-lg px-4 gap-3" %>
        <%= link_to "Learn More", "#", class: "btn btn-outline-secondary btn-lg px-4" %>
      </div>
    </div>
  </div>

  <div class="row g-4 py-4">
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">Rails 8</h5>
          <p class="card-text">Built on the latest Rails with modern defaults, Propshaft asset pipeline, and Kamal deployment.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">Solid Queue</h5>
          <p class="card-text">Database-backed job processing with Solid Queue for reliable background task execution.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">Hotwire</h5>
          <p class="card-text">Turbo and Stimulus deliver SPA-like speed without the complexity of a full JavaScript framework.</p>
        </div>
      </div>
    </div>
  </div>
</div>
