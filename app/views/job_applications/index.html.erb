<% content_for(:page_title, "Applications") %>

<%= render "shared/page_header", title: "Applications", subtitle: "#{@applications.size} applications" %>

<%# ── Status Filter Tabs ── %>
<ul class="nav nav-tabs mb-4">
  <li class="nav-item">
    <%= link_to "All (#{@status_counts.values.sum})", job_applications_path,
        class: "nav-link #{params[:status].blank? ? 'active' : ''}" %>
  </li>
  <% JobApplication::STATUSES.each do |s| %>
    <% count = @status_counts[s] || 0 %>
    <% next if count == 0 && s != params[:status] %>
    <li class="nav-item">
      <%= link_to "#{s.humanize} (#{count})", job_applications_path(status: s),
          class: "nav-link #{params[:status] == s ? 'active' : ''}" %>
    </li>
  <% end %>
</ul>

<% if @applications.any? %>
  <div class="card dash-table-card">
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th scope="col">Position</th>
            <th scope="col">Company</th>
            <th scope="col"><%= link_to "Status#{sort_indicator('status')}", sort_url('status', job_applications_path), class: "text-decoration-none text-dark" %></th>
            <th scope="col">Steps</th>
            <th scope="col"><%= link_to "Applied#{sort_indicator('created_at')}", sort_url('created_at', job_applications_path), class: "text-decoration-none text-dark" %></th>
            <th scope="col">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @applications.each do |app| %>
            <tr>
              <td>
                <%= link_to app.job_listing.title, job_application_path(app), class: "fw-bold text-decoration-none" %>
              </td>
              <td><%= app.job_listing.company %></td>
              <td>
                <span class="badge bg-<%= application_status_color(app.status) %>"><%= app.status.humanize %></span>
              </td>
              <td><%= app.application_steps.count %></td>
              <td class="text-muted">
                <%= app.applied_at ? time_ago_in_words(app.applied_at) + " ago" : "Pending" %>
              </td>
              <td>
                <%= link_to "View", job_application_path(app), class: "btn btn-sm btn-outline-primary" %>
                <% if app.can_retry? %>
                  <%= button_to "Retry", retry_application_job_application_path(app), method: :post, class: "btn btn-sm btn-outline-warning" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <div class="card source-empty-card">
    <div class="card-body text-center py-5">
      <div class="source-empty-card__icon mb-3">&#x1F4E8;</div>
      <h3>No applications yet</h3>
      <p class="text-muted mb-3">Apply to jobs from the listings page to start tracking your applications.</p>
      <%= link_to "Browse Job Listings", job_listings_path, class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
