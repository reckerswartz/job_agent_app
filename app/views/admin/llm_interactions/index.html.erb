<% content_for(:page_title, "Admin — LLM Interactions") %>

<%= render "shared/page_header", title: "LLM Interactions", subtitle: "#{LlmInteraction.count} total interactions" %>

<div class="d-flex gap-2 mb-3">
  <%= form_tag admin_llm_interactions_path, method: :get, class: "d-flex gap-2 align-items-center" do %>
    <select name="feature" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
      <option value="">All Features</option>
      <% LlmInteraction.distinct.pluck(:feature_name).compact.sort.each do |f| %>
        <option value="<%= f %>" <%= 'selected' if params[:feature] == f %>><%= f.humanize %></option>
      <% end %>
    </select>
    <select name="status" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
      <option value="">All Statuses</option>
      <% %w[completed failed pending].each do |s| %>
        <option value="<%= s %>" <%= 'selected' if params[:status] == s %>><%= s.capitalize %></option>
      <% end %>
    </select>
    <% if params[:feature].present? || params[:status].present? %>
      <%= link_to "Clear", admin_llm_interactions_path, class: "btn btn-sm btn-outline-secondary" %>
    <% end %>
  <% end %>
</div>

<div class="card dash-table-card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>User</th>
          <th>Feature</th>
          <th>Model</th>
          <th>Status</th>
          <th>Tokens</th>
          <th>Latency</th>
          <th>When</th>
        </tr>
      </thead>
      <tbody>
        <% @interactions.each do |interaction| %>
          <tr>
            <td><%= link_to "##{interaction.id}", admin_llm_interaction_path(interaction), class: "fw-bold text-decoration-none" %></td>
            <td><%= interaction.user&.email&.truncate(25) %></td>
            <td><span class="badge bg-info"><%= interaction.feature_name %></span></td>
            <td class="small"><%= interaction.llm_model&.name || "—" %></td>
            <td><span class="badge bg-<%= interaction.status == 'completed' ? 'success' : (interaction.status == 'failed' ? 'danger' : 'secondary') %>"><%= interaction.status %></span></td>
            <td><%= interaction.token_usage["total_tokens"] || "—" %></td>
            <td><%= interaction.latency_ms ? "#{interaction.latency_ms}ms" : "—" %></td>
            <td class="text-muted"><%= time_ago_in_words(interaction.created_at) %> ago</td>
          </tr>
        <% end %>
        <% if @interactions.empty? %>
          <tr><td colspan="8" class="text-center text-muted">No LLM interactions yet</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= render "shared/pagination", pagy: @pagy %>
