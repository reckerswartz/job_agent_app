<% content_for(:page_title, "Admin Dashboard") %>

<div class="page-header mb-4">
  <h1 class="page-header__title">Admin Dashboard</h1>
  <p class="page-header__subtitle">System overview</p>
</div>

<%# ── Stats Row ── %>
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-2">
    <div class="card stat-card">
      <div class="card-body">
        <div class="stat-card__body">
          <div class="stat-card__value"><%= @total_users %></div>
          <div class="stat-card__label">Users</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-2">
    <div class="card stat-card">
      <div class="card-body">
        <div class="stat-card__body">
          <div class="stat-card__value"><%= @total_listings %></div>
          <div class="stat-card__label">Listings</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-2">
    <div class="card stat-card">
      <div class="card-body">
        <div class="stat-card__body">
          <div class="stat-card__value"><%= @total_applications %></div>
          <div class="stat-card__label">Applications</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-2">
    <div class="card stat-card">
      <div class="card-body">
        <div class="stat-card__body">
          <div class="stat-card__value"><%= @total_scans %></div>
          <div class="stat-card__label">Scans</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-2">
    <div class="card stat-card">
      <div class="card-body">
        <div class="stat-card__body">
          <div class="stat-card__value"><%= @pending_interventions %></div>
          <div class="stat-card__label">Pending</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-2">
    <div class="card stat-card">
      <div class="card-body">
        <div class="stat-card__body">
          <div class="stat-card__value"><%= @llm_stats[:total] %></div>
          <div class="stat-card__label">LLM Calls</div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <%# ── Recent Users ── %>
  <div class="col-xl-6">
    <div class="card dash-table-card">
      <div class="card-header">
        <h2 class="card-header__title">Recent Users</h2>
        <%= link_to "View All", admin_users_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr><th>Email</th><th>Role</th><th>Sign-ins</th><th>Joined</th></tr>
          </thead>
          <tbody>
            <% @recent_users.each do |user| %>
              <tr>
                <td><%= link_to user.email, admin_user_path(user), class: "text-decoration-none" %></td>
                <td><span class="badge bg-<%= user.admin? ? 'danger' : 'secondary' %>"><%= user.role %></span></td>
                <td><%= user.sign_in_count %></td>
                <td class="text-muted"><%= time_ago_in_words(user.created_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# ── Recent Scans ── %>
  <div class="col-xl-6">
    <div class="card dash-table-card">
      <div class="card-header">
        <h2 class="card-header__title">Recent Scans</h2>
        <%= link_to "View All", admin_scan_runs_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr><th>Source</th><th>Status</th><th>Found</th><th>New</th><th>When</th></tr>
          </thead>
          <tbody>
            <% @recent_scans.each do |run| %>
              <tr>
                <td><%= run.job_source.name %></td>
                <td><span class="badge bg-<%= scan_status_color(run.status) %>"><%= run.status.capitalize %></span></td>
                <td><%= run.listings_found %></td>
                <td><%= run.new_listings %></td>
                <td class="text-muted"><%= run.created_at ? time_ago_in_words(run.created_at) + " ago" : "—" %></td>
              </tr>
            <% end %>
            <% if @recent_scans.empty? %>
              <tr><td colspan="5" class="text-center text-muted">No scans yet</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%# ── LLM Stats ── %>
<div class="row g-3 mt-2">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h2 class="card-header__title">LLM Usage</h2>
        <%= link_to "View Logs", admin_llm_interactions_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="card-body">
        <div class="row text-center">
          <div class="col-4">
            <div class="fw-bold fs-4"><%= @llm_stats[:total] %></div>
            <div class="text-muted small">Total Calls</div>
          </div>
          <div class="col-4">
            <div class="fw-bold fs-4 text-success"><%= @llm_stats[:completed] %></div>
            <div class="text-muted small">Completed</div>
          </div>
          <div class="col-4">
            <div class="fw-bold fs-4 text-danger"><%= @llm_stats[:failed] %></div>
            <div class="text-muted small">Failed</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
