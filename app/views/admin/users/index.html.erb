<% content_for(:page_title, "Admin — Users") %>

<%= render "shared/page_header", title: "Users", subtitle: "#{User.count} total users" %>

<div data-controller="data-table" class="mb-3 d-flex gap-2 align-items-center">
  <input type="text" class="form-control form-control-sm" style="max-width: 280px;"
         placeholder="Search by email..." value="<%= params[:q] %>"
         data-data-table-target="searchInput" data-action="input->data-table#search">
</div>

<div class="card dash-table-card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th scope="col"><%= link_to "Email#{sort_indicator('email')}", sort_url('email', admin_users_path), class: "text-decoration-none text-dark" %></th>
          <th scope="col"><%= link_to "Role#{sort_indicator('role')}", sort_url('role', admin_users_path), class: "text-decoration-none text-dark" %></th>
          <th scope="col"><%= link_to "Sign-ins#{sort_indicator('sign_in_count')}", sort_url('sign_in_count', admin_users_path), class: "text-decoration-none text-dark" %></th>
          <th scope="col">Last Sign-in</th>
          <th scope="col">Sources</th>
          <th scope="col">Listings</th>
          <th scope="col"><%= link_to "Joined#{sort_indicator('created_at')}", sort_url('created_at', admin_users_path), class: "text-decoration-none text-dark" %></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= link_to user.email, admin_user_path(user), class: "fw-bold text-decoration-none" %></td>
            <td><span class="badge bg-<%= user.admin? ? 'danger' : 'secondary' %>"><%= user.role %></span></td>
            <td><%= user.sign_in_count %></td>
            <td class="text-muted"><%= user.last_sign_in_at ? time_ago_in_words(user.last_sign_in_at) + " ago" : "Never" %></td>
            <td><%= @source_counts[user.id] || 0 %></td>
            <td><%= @listing_counts[user.id] || 0 %></td>
            <td class="text-muted"><%= time_ago_in_words(user.created_at) %> ago</td>
          </tr>
        <% end %>
        <% if @users.empty? %>
          <tr><td colspan="7" class="text-center text-muted">No users found</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= render "shared/pagination", pagy: @pagy %>
