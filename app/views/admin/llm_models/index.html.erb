<% content_for(:page_title, "Admin — LLM Models") %>

<div class="page-header mb-4">
  <h1 class="page-header__title">LLM Model Configuration</h1>
  <p class="page-header__subtitle">Configure which models handle text processing, vision tasks, and verification</p>
</div>

<div class="card dash-table-card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>Model</th>
          <th>Identifier</th>
          <th>Type</th>
          <th>Provider</th>
          <th>Active</th>
          <th>Role</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @models.each do |model| %>
          <tr>
            <td class="fw-bold"><%= model.name %></td>
            <td class="small text-muted"><%= model.identifier %></td>
            <td>
              <% color = { "text" => "primary", "vision" => "warning", "multimodal" => "info" }[model.model_type] || "secondary" %>
              <span class="badge bg-<%= color %>"><%= model.model_type.capitalize %></span>
            </td>
            <td><%= model.llm_provider.name %></td>
            <td>
              <%= form_with model: [:admin, model], method: :patch, class: "d-inline" do |f| %>
                <%= f.hidden_field :active, value: !model.active %>
                <%= f.hidden_field :role, value: model.role %>
                <button type="submit" class="btn btn-sm <%= model.active? ? 'btn-success' : 'btn-outline-secondary' %>">
                  <%= model.active? ? "On" : "Off" %>
                </button>
              <% end %>
            </td>
            <td>
              <%= form_with model: [:admin, model], method: :patch, class: "d-inline" do |f| %>
                <%= f.hidden_field :active, value: model.active %>
                <%= f.select :role,
                    options_for_select(
                      [["— None —", ""], ["Primary Text", "primary_text"], ["Primary Vision", "primary_vision"], ["Verification", "verification"]],
                      model.role
                    ),
                    {},
                    class: "form-select form-select-sm d-inline-block", style: "width: 160px;",
                    onchange: "this.form.requestSubmit()" %>
              <% end %>
            </td>
            <td>
              <% if model.role.present? %>
                <span class="badge bg-success">Assigned</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="card mt-4">
  <div class="card-header"><h3 class="card-header__title mb-0">How Roles Work</h3></div>
  <div class="card-body">
    <dl class="listing-details mb-0">
      <dt>Primary Text</dt>
      <dd>Used for resume text structuring, cover letter generation, and text-based matching</dd>
      <dt>Primary Vision</dt>
      <dd>Used for extracting text from resume images (JPG, PNG, WebP)</dd>
      <dt>Verification</dt>
      <dd>Optional second model that cross-checks extracted data for accuracy</dd>
    </dl>
  </div>
</div>
