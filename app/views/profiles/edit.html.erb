<% content_for(:page_title, "Edit Profile") %>

<div class="page-header d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="page-header__title">Edit Profile</h1>
    <p class="page-header__subtitle">
      <span class="badge bg-<%= @profile.complete? ? 'success' : 'warning' %>"><%= @profile.status.capitalize %></span>
    </p>
  </div>
  <%= link_to "View Profile", profile_path, class: "btn btn-outline-primary" %>
</div>

<%# ── Tab Navigation ── %>
<ul class="nav nav-tabs profile-tabs mb-4" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="resume-tab" data-bs-toggle="tab" data-bs-target="#resume" type="button" role="tab">Resume</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab">Contact</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="work_experience-tab" data-bs-toggle="tab" data-bs-target="#work_experience" type="button" role="tab">Experience</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="education-tab" data-bs-toggle="tab" data-bs-target="#education" type="button" role="tab">Education</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="skills-tab" data-bs-toggle="tab" data-bs-target="#skills" type="button" role="tab">Skills</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="other-tab" data-bs-toggle="tab" data-bs-target="#other" type="button" role="tab">Other</button>
  </li>
</ul>

<%# ── Tab Content ── %>
<div class="tab-content">
  <%# ── Tab 1: Resume Upload ── %>
  <div class="tab-pane fade show active" id="resume" role="tabpanel">
    <%= render "profiles/resume_upload", profile: @profile %>
  </div>

  <%# ── Tab 2: Contact Details ── %>
  <div class="tab-pane fade" id="contact" role="tabpanel">
    <%= render "profiles/contact_form", profile: @profile %>
  </div>

  <%# ── Tab 3: Work Experience ── %>
  <div class="tab-pane fade" id="work_experience" role="tabpanel">
    <%= render "profiles/section_tab", profile: @profile, section_type: "work_experience" %>
  </div>

  <%# ── Tab 4: Education ── %>
  <div class="tab-pane fade" id="education" role="tabpanel">
    <%= render "profiles/section_tab", profile: @profile, section_type: "education" %>
  </div>

  <%# ── Tab 5: Skills ── %>
  <div class="tab-pane fade" id="skills" role="tabpanel">
    <%= render "profiles/section_tab", profile: @profile, section_type: "skills" %>
  </div>

  <%# ── Tab 6: Other (Certifications, Projects, Languages) ── %>
  <div class="tab-pane fade" id="other" role="tabpanel">
    <% %w[certifications projects languages].each do |type| %>
      <%= render "profiles/section_tab", profile: @profile, section_type: type %>
    <% end %>
  </div>
</div>
