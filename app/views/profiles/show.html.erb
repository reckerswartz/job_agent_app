<% content_for(:page_title, "My Profile") %>

<div class="page-header d-flex justify-content-between align-items-start">
  <div>
    <h1 class="page-header__title">My Profile</h1>
    <p class="page-header__subtitle">
      <span class="badge bg-<%= @profile.complete? ? 'success' : 'warning' %>"><%= @profile.status.capitalize %></span>
    </p>
  </div>
  <div class="d-flex gap-2">
    <% if @profile.source_text.present? && llm_available? %>
      <%= button_to "Structure with AI", structure_with_ai_profile_path, method: :post, class: "btn btn-outline-primary", form: { data: { controller: "loading-button", action: "submit->loading-button#submit", loading_button_text_value: "Structuring..." } } %>
    <% end %>
    <%= link_to "Edit Profile", edit_profile_path, class: "btn btn-primary" %>
  </div>
</div>

<%= render "profiles/processing_banner", profile: @profile %>

<%# ── Completeness Progress ── %>
<% completeness = @profile.completeness_percentage %>
<% if completeness < 100 %>
  <div class="card mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <strong>Profile Completeness</strong>
        <span class="fw-bold"><%= completeness %>%</span>
      </div>
      <div class="progress" style="height: 8px;">
        <div class="progress-bar bg-<%= completeness >= 70 ? 'success' : (completeness >= 40 ? 'warning' : 'danger') %>"
             style="width: <%= completeness %>%"></div>
      </div>
      <small class="text-muted mt-1 d-block">
        <% missing = [] %>
        <% missing << "contact details" unless @profile.contact_details.values_at("first_name", "surname", "email").all?(&:present?) %>
        <% missing << "headline" unless @profile.headline.present? %>
        <% missing << "summary" unless @profile.summary.present? %>
        <% missing << "resume" unless @profile.source_document.attached? %>
        <% missing << "profile sections" unless @profile.profile_sections.joins(:profile_entries).exists? %>
        <% if missing.any? %>
          Missing: <%= missing.join(", ") %>
        <% end %>
      </small>
    </div>
  </div>
<% end %>

<%# ── Contact Card ── %>
<div class="card profile-card mb-4">
  <div class="card-body">
    <h2 class="profile-card__name"><%= @profile.display_name %></h2>
    <% if @profile.headline.present? %>
      <p class="profile-card__headline"><%= @profile.headline %></p>
    <% end %>

    <div class="profile-card__contact">
      <% if @profile.contact_field("email").present? %>
        <span class="profile-card__contact-item">&#x2709; <%= @profile.contact_field("email") %></span>
      <% end %>
      <% if @profile.contact_field("phone").present? %>
        <span class="profile-card__contact-item">&#x260E; <%= @profile.contact_field("phone") %></span>
      <% end %>
      <% if @profile.contact_field("city").present? || @profile.contact_field("country").present? %>
        <span class="profile-card__contact-item">&#x1F4CD; <%= [@profile.contact_field("city"), @profile.contact_field("country")].reject(&:blank?).join(", ") %></span>
      <% end %>
      <% if @profile.contact_field("linkedin").present? %>
        <span class="profile-card__contact-item">&#x1F517; <%= link_to "LinkedIn", @profile.contact_field("linkedin"), target: "_blank" %></span>
      <% end %>
    </div>
  </div>
</div>

<%# ── Summary ── %>
<% if @profile.summary.present? %>
  <div class="card mb-4">
    <div class="card-header"><h3 class="card-header__title mb-0">Summary</h3></div>
    <div class="card-body">
      <p class="mb-0"><%= simple_format(@profile.summary) %></p>
    </div>
  </div>
<% end %>

<%# ── Sections ── %>
<% @profile.profile_sections.includes(:profile_entries).each do |section| %>
  <div class="card mb-4">
    <div class="card-header">
      <h3 class="card-header__title mb-0"><%= section.title %></h3>
    </div>
    <div class="card-body">
      <% if section.profile_entries.any? %>
        <% section.ordered_entries.each do |entry| %>
          <%= render "profiles/entries/#{section.section_type}", entry: entry %>
        <% end %>
      <% else %>
        <p class="text-muted mb-0">No entries yet.</p>
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Extracted Text ── %>
<% if @profile.source_text.present? %>
  <div class="card mb-4">
    <div class="card-header"><h3 class="card-header__title mb-0">Extracted Resume Text</h3></div>
    <div class="card-body">
      <pre class="profile-extracted-text"><%= @profile.source_text %></pre>
    </div>
  </div>
<% end %>
