<%= form_with url: profile_section_entry_path(section, entry), method: :patch do |f| %>
  <div class="row g-2 mb-2">
    <div class="col-md-6">
      <input type="text" name="profile_entry[content][title]" value="<%= entry.content["title"] %>" class="form-control form-control-sm" placeholder="Job Title">
    </div>
    <div class="col-md-6">
      <input type="text" name="profile_entry[content][company]" value="<%= entry.content["company"] %>" class="form-control form-control-sm" placeholder="Company">
    </div>
    <div class="col-md-4">
      <input type="text" name="profile_entry[content][location]" value="<%= entry.content["location"] %>" class="form-control form-control-sm" placeholder="Location">
    </div>
    <div class="col-md-3">
      <input type="text" name="profile_entry[content][start_date]" value="<%= entry.content["start_date"] %>" class="form-control form-control-sm" placeholder="Start (e.g. Jan 2020)">
    </div>
    <div class="col-md-3">
      <input type="text" name="profile_entry[content][end_date]" value="<%= entry.content["end_date"] %>" class="form-control form-control-sm" placeholder="End (or Present)">
    </div>
    <div class="col-md-2 d-flex align-items-center">
      <div class="form-check">
        <input type="checkbox" name="profile_entry[content][current]" value="true" class="form-check-input" <%= "checked" if entry.content["current"] == "true" %>>
        <label class="form-check-label small">Current</label>
      </div>
    </div>
    <div class="col-12">
      <textarea name="profile_entry[content][description]" class="form-control form-control-sm" rows="2" placeholder="Description"><%= entry.content["description"] %></textarea>
    </div>
  </div>
  <div class="d-flex gap-2">
    <%= f.submit "Update", class: "btn btn-sm btn-primary" %>
    <%= button_to "Remove", profile_section_entry_path(section, entry), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Remove this entry?" } %>
  </div>
<% end %>
