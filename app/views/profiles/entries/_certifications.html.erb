<div class="entry-display">
  <strong><%= entry.content["name"] %></strong>
  <% if entry.content["issuer"].present? %>
    <span class="text-muted">— <%= entry.content["issuer"] %></span>
  <% end %>
  <% if entry.content["date"].present? %>
    <small class="text-muted ms-2"><%= entry.content["date"] %></small>
  <% end %>
</div>
