<%= form_with url: profile_section_entry_path(section, entry), method: :patch, class: "d-flex gap-2 align-items-center mb-2" do |f| %>
  <input type="text" name="profile_entry[content][name]" value="<%= entry.content["name"] %>" class="form-control form-control-sm" placeholder="Certification">
  <input type="text" name="profile_entry[content][issuer]" value="<%= entry.content["issuer"] %>" class="form-control form-control-sm" placeholder="Issuer">
  <input type="text" name="profile_entry[content][date]" value="<%= entry.content["date"] %>" class="form-control form-control-sm" style="width:120px" placeholder="Date">
  <%= f.submit "Save", class: "btn btn-sm btn-primary" %>
  <%= button_to "x", profile_section_entry_path(section, entry), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Remove?" } %>
<% end %>
