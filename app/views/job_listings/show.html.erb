<% content_for(:page_title, @listing.title) %>

<div class="page-header mb-4">
  <div class="d-flex justify-content-between align-items-start">
    <div>
      <h1 class="page-header__title"><%= @listing.title %></h1>
      <p class="page-header__subtitle">
        <%= @listing.company %>
        <% if @listing.location.present? %> &middot; <%= @listing.location %><% end %>
      </p>
    </div>
    <div class="d-flex gap-2">
      <% if @listing.job_application.present? %>
        <%= link_to "View Application", job_application_path(@listing.job_application), class: "btn btn-sm btn-info" %>
      <% else %>
        <%= button_to "Apply Now", job_applications_path(job_listing_id: @listing.id), method: :post, class: "btn btn-sm btn-primary" %>
      <% end %>
      <% if @listing.status == "new" || @listing.status == "reviewed" %>
        <%= button_to "Save", update_status_job_listing_path(@listing, new_status: "saved"), method: :patch, class: "btn btn-sm btn-success" %>
        <%= button_to "Reject", update_status_job_listing_path(@listing, new_status: "rejected"), method: :patch, class: "btn btn-sm btn-outline-danger" %>
      <% end %>
      <%= link_to "Back to Listings", job_listings_path, class: "btn btn-sm btn-outline-secondary" %>
    </div>
  </div>
</div>

<div class="row g-4">
  <%# ── Main Content ── %>
  <div class="col-lg-8">
    <% if @listing.description.present? %>
      <div class="card mb-4">
        <div class="card-header"><h3 class="card-header__title mb-0">Description</h3></div>
        <div class="card-body"><%= simple_format(@listing.description) %></div>
      </div>
    <% end %>

    <% if @listing.requirements.present? %>
      <div class="card mb-4">
        <div class="card-header"><h3 class="card-header__title mb-0">Requirements</h3></div>
        <div class="card-body"><%= simple_format(@listing.requirements) %></div>
      </div>
    <% end %>

    <%# ── Cover Letter ── %>
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-header__title mb-0">Cover Letter</h3>
        <% if llm_available? %>
          <% if @listing.metadata["cover_letter"].present? %>
            <%= button_to "Regenerate", generate_cover_letter_job_listing_path(@listing), method: :post, class: "btn btn-sm btn-outline-primary" %>
          <% else %>
            <%= button_to "Generate with AI", generate_cover_letter_job_listing_path(@listing), method: :post, class: "btn btn-sm btn-primary" %>
          <% end %>
        <% end %>
      </div>
      <div class="card-body">
        <% if @listing.metadata["cover_letter"].present? %>
          <%= simple_format(@listing.metadata["cover_letter"]) %>
        <% else %>
          <p class="text-muted mb-0">
            <% if llm_available? %>
              Click "Generate with AI" to create a tailored cover letter for this position.
            <% else %>
              Set your NVIDIA API key in Settings to enable AI cover letter generation.
            <% end %>
          </p>
        <% end %>
      </div>
    </div>
  </div>

    <%# ── Notes ── %>
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-header__title mb-0">Notes</h3>
      </div>
      <div class="card-body">
        <div id="notes_list">
          <%= render partial: "job_listing_notes/note", collection: @listing.job_listing_notes.where(user: current_user).recent, as: :note %>
        </div>

        <%= form_with url: job_listing_notes_path(@listing), class: "d-flex gap-2", id: "new_note_form" do |f| %>
          <textarea name="job_listing_note[content]" class="form-control form-control-sm" rows="2" placeholder="Add a note about this listing..." required></textarea>
          <button type="submit" class="btn btn-sm btn-primary align-self-end flex-shrink-0">
            <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Sidebar Info ── %>
  <div class="col-lg-4">
    <div class="card mb-4">
      <div class="card-header"><h3 class="card-header__title mb-0">Details</h3></div>
      <div class="card-body">
        <dl class="listing-details">
          <% if @listing.match_score %>
            <dt>Match Score</dt>
            <dd><span class="match-score <%= @listing.match_badge_class %>"><%= @listing.match_score %>%</span></dd>
          <% end %>
          <dt>Status</dt>
          <dd><span class="badge bg-<%= status_badge_color(@listing.status) %>"><%= @listing.status.capitalize %></span></dd>
          <dt>Source</dt>
          <dd>
            <span class="badge bg-<%= @listing.job_source.platform_color %> source-badge"><%= @listing.job_source.platform.capitalize %></span>
            <% if @listing.easy_apply? %>
              <span class="badge bg-success ms-1">Easy Apply</span>
            <% end %>
          </dd>
          <% if @listing.salary_range.present? %>
            <dt>Salary</dt>
            <dd><%= @listing.salary_range %></dd>
          <% end %>
          <% if @listing.employment_type.present? %>
            <dt>Type</dt>
            <dd><%= @listing.employment_type.humanize %></dd>
          <% end %>
          <% if @listing.remote_type.present? %>
            <dt>Remote</dt>
            <dd><%= @listing.remote_type.humanize %></dd>
          <% end %>
          <% if @listing.posted_at.present? %>
            <dt>Posted</dt>
            <dd><%= time_ago_in_words(@listing.posted_at) %> ago</dd>
          <% end %>
          <% if @listing.application_url.present? %>
            <dt>Apply Link</dt>
            <dd><%= link_to "Apply on Company Site", @listing.application_url, target: "_blank", class: "btn btn-sm btn-primary" %></dd>
          <% end %>
          <% if @listing.url.present? %>
            <dt>Link</dt>
            <dd><%= link_to "View Original", safe_external_url(@listing.url), target: "_blank", rel: "noopener noreferrer", class: "btn btn-sm btn-outline-primary" %></dd>
          <% end %>
        </dl>
      </div>
    </div>

    <%# ── Match Analysis Card ── %>
    <% if @listing.match_score %>
      <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h3 class="card-header__title mb-0">Match Analysis</h3>
          <% if llm_available? %>
            <%= button_to "Analyze with AI", analyze_match_job_listing_path(@listing), method: :post,
                class: "btn btn-sm btn-outline-primary",
                form: { data: { controller: "loading-button", action: "submit->loading-button#submit", loading_button_text_value: "Analyzing..." } } %>
          <% end %>
        </div>
        <div class="card-body">
          <% bd = @listing.match_breakdown || {} %>

          <%# ── Category Breakdown ── %>
          <% %w[title skills location salary recency source].each do |cat| %>
            <% cat_data = bd[cat] || bd[cat.to_sym] %>
            <% next unless cat_data %>
            <div class="mb-3">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-semibold small"><%= cat.capitalize %></span>
                <span class="small text-muted"><%= cat_data["score"] || cat_data[:score] %>% (<%= cat_data["weight"] || cat_data[:weight] %>% weight)</span>
              </div>
              <div class="progress" style="height: 6px;">
                <% s = cat_data["score"] || cat_data[:score] || 0 %>
                <div class="progress-bar bg-<%= s >= 70 ? 'success' : (s >= 40 ? 'warning' : 'danger') %>" style="width: <%= s %>%;"></div>
              </div>
              <% detail = cat_data["detail"] || cat_data[:detail] %>
              <% if detail.present? %>
                <div class="text-muted" style="font-size: 0.7rem;"><%= detail %></div>
              <% end %>
              <% matched = cat_data["matched"] || cat_data[:matched] %>
              <% missing = cat_data["missing"] || cat_data[:missing] %>
              <% if matched.present? %>
                <div style="font-size: 0.7rem;">
                  <span class="text-success"><%= matched.join(", ") %></span>
                  <% if missing.present? %>
                    <span class="text-muted"> | </span>
                    <span class="text-danger"><%= missing.join(", ") %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>

          <%# ── LLM Analysis (if available) ── %>
          <% llm = bd["llm_analysis"] || bd[:llm_analysis] %>
          <% if llm.present? %>
            <hr>
            <div class="mb-2">
              <% rec = llm["recommendation"] || llm[:recommendation] %>
              <% rec_color = { "strong_match" => "success", "good_match" => "primary", "partial_match" => "warning", "weak_match" => "danger" }[rec] || "secondary" %>
              <span class="badge bg-<%= rec_color %>"><%= rec&.humanize %></span>
              <span class="small text-muted ms-2">AI Analysis</span>
            </div>
            <% summary = llm["summary"] || llm[:summary] %>
            <% if summary.present? %>
              <p class="small mb-2"><%= summary %></p>
            <% end %>
            <% reasons = llm["reasons"] || llm[:reasons] %>
            <% if reasons.present? %>
              <ul class="small mb-2">
                <% reasons.each { |r| %><li><%= r %></li><% } %>
              </ul>
            <% end %>
            <% gaps = llm["skill_gaps"] || llm[:skill_gaps] %>
            <% if gaps.present? %>
              <div class="small"><strong>Skill gaps:</strong> <span class="text-danger"><%= gaps.join(", ") %></span></div>
            <% end %>
            <% salary = llm["salary_estimate"] || llm[:salary_estimate] %>
            <% if salary.present? && salary != "null" %>
              <div class="small mt-1"><strong>Est. salary:</strong> <%= salary %></div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
