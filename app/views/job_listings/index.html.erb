<% content_for(:page_title, "Job Listings") %>

<% actions = capture do %>
  <% if @listings.any? %>
    <%= link_to "Export CSV", export_job_listings_path(status: params[:status]), class: "btn btn-outline-secondary btn-sm" %>
  <% end %>
<% end %>
<%= render "shared/page_header", title: "Job Listings", subtitle: "#{@listings.size} listings found", actions: actions %>

<%# ── Search Bar ── %>
<div class="mb-3">
  <%= form_with url: job_listings_path, method: :get, class: "d-flex gap-2", data: { turbo_frame: "_top" } do %>
    <input type="hidden" name="status" value="<%= params[:status] %>">
    <input type="text" name="q" value="<%= @search_query %>" class="form-control" placeholder="Search by title, company, or location..." autofocus>
    <button type="submit" class="btn btn-primary">Search</button>
    <% if @search_query.present? %>
      <%= link_to "Clear", job_listings_path(status: params[:status]), class: "btn btn-outline-secondary" %>
    <% end %>
  <% end %>
</div>

<%# ── Advanced Filters (collapsible) ── %>
<div class="mb-3">
  <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFilters" aria-expanded="<%= @filters_active ? 'true' : 'false' %>" aria-controls="advancedFilters">
    <i class="bi bi-funnel"></i> Filters <%= "(active)" if @filters_active %>
  </button>
</div>
<div class="collapse <%= 'show' if @filters_active %>" id="advancedFilters">
  <div class="card mb-3">
    <div class="card-body py-2 px-3">
      <%= form_with url: job_listings_path, method: :get, class: "row g-2 align-items-end" do %>
        <input type="hidden" name="status" value="<%= params[:status] %>">
        <input type="hidden" name="q" value="<%= params[:q] %>">
        <div class="col-auto">
          <label class="form-label small mb-0">Remote</label>
          <select name="remote" class="form-select form-select-sm" style="width: 120px;">
            <option value="">Any</option>
            <% %w[remote hybrid onsite].each do |r| %>
              <option value="<%= r %>" <%= 'selected' if params[:remote] == r %>><%= r.capitalize %></option>
            <% end %>
          </select>
        </div>
        <div class="col-auto">
          <label class="form-label small mb-0">Type</label>
          <select name="employment" class="form-select form-select-sm" style="width: 130px;">
            <option value="">Any</option>
            <% %w[full_time part_time contract internship].each do |t| %>
              <option value="<%= t %>" <%= 'selected' if params[:employment] == t %>><%= t.humanize %></option>
            <% end %>
          </select>
        </div>
        <div class="col-auto">
          <label class="form-label small mb-0">Source</label>
          <select name="platform" class="form-select form-select-sm" style="width: 120px;">
            <option value="">All</option>
            <% JobSource::PLATFORMS.each do |p| %>
              <option value="<%= p %>" <%= 'selected' if params[:platform] == p %>><%= p.capitalize %></option>
            <% end %>
          </select>
        </div>
        <div class="col-auto">
          <label class="form-label small mb-0">Match</label>
          <div class="d-flex gap-1">
            <input type="number" name="min_match" value="<%= params[:min_match] %>" class="form-control form-control-sm" style="width: 65px;" placeholder="Min" min="0" max="100">
            <input type="number" name="max_match" value="<%= params[:max_match] %>" class="form-control form-control-sm" style="width: 65px;" placeholder="Max" min="0" max="100">
          </div>
        </div>
        <div class="col-auto">
          <div class="form-check form-check-inline mb-0">
            <input type="checkbox" name="easy_apply" value="1" class="form-check-input" id="filter_easy_apply" <%= 'checked' if params[:easy_apply] == '1' %>>
            <label class="form-check-label small" for="filter_easy_apply">Easy Apply</label>
          </div>
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-sm btn-primary">Filter</button>
          <% if @filters_active %>
            <%= link_to "Clear", job_listings_path(status: params[:status], q: params[:q]), class: "btn btn-sm btn-outline-secondary" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Status Filter Tabs ── %>
<% listing_tabs = [{ label: "All", count: @status_counts.values.sum, path: job_listings_path, active: params[:status].blank? }] %>
<% JobListing::STATUSES.each do |s| %>
  <% count = @status_counts[s] || 0 %>
  <% next if count == 0 && s != params[:status] %>
  <% listing_tabs << { label: s.capitalize, count: count, path: job_listings_path(status: s), active: params[:status] == s } %>
<% end %>
<%= render "shared/filter_tabs", tabs: listing_tabs %>

<% if @listings.any? %>
  <div data-controller="bulk-select">
    <%# ── Bulk Action Bar ── %>
    <div class="d-flex gap-2 align-items-center mb-3 p-2 bg-light rounded" style="display:none;" data-bulk-select-target="actionBar">
      <span class="fw-bold small" data-bulk-select-target="count">0 selected</span>
      <button type="button" class="btn btn-sm btn-success" data-action="click->bulk-select#submitBulk" data-status="saved">Save Selected</button>
      <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->bulk-select#submitBulk" data-status="rejected">Reject Selected</button>
    </div>

    <div class="card dash-table-card">
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th scope="col" style="width:40px"><input type="checkbox" class="form-check-input" data-bulk-select-target="selectAll" data-action="change->bulk-select#toggleAll"></th>
              <th scope="col"><%= link_to "Position#{sort_indicator('title')}", sort_url('title', job_listings_path), class: "text-decoration-none text-dark" %></th>
              <th scope="col"><%= link_to "Company#{sort_indicator('company')}", sort_url('company', job_listings_path), class: "text-decoration-none text-dark" %></th>
              <th scope="col">Location</th>
              <th scope="col"><%= link_to "Match#{sort_indicator('match_score')}", sort_url('match_score', job_listings_path), class: "text-decoration-none text-dark" %></th>
              <th scope="col">Source</th>
              <th scope="col">Status</th>
              <th scope="col"><%= link_to "Posted#{sort_indicator('posted_at')}", sort_url('posted_at', job_listings_path), class: "text-decoration-none text-dark" %></th>
            </tr>
          </thead>
          <tbody>
            <% @listings.each do |listing| %>
              <tr>
                <td><input type="checkbox" class="form-check-input" value="<%= listing.id %>" data-bulk-select-target="checkbox" data-action="change->bulk-select#toggle"></td>
                <td>
                  <%= link_to listing.title, job_listing_path(listing), class: "fw-bold text-decoration-none" %>
                </td>
                <td><%= listing.company %></td>
                <td><%= listing.location %></td>
                <td>
                  <% if listing.match_score %>
                    <span class="match-score <%= listing.match_badge_class %>"><%= listing.match_score %>%</span>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td>
                  <span class="badge bg-<%= listing.job_source.platform_color %> source-badge">
                    <%= listing.job_source.platform.capitalize %>
                  </span>
                </td>
                <td>
                  <span class="badge bg-<%= status_badge_color(listing.status) %>"><%= listing.status.capitalize %></span>
                </td>
                <td class="text-muted">
                  <%= listing.posted_at ? time_ago_in_words(listing.posted_at) + " ago" : "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <%= render "shared/empty_state", icon: "bi-list-ul", title: "No job listings yet",
      message: "Add job sources and run a scan to discover listings.",
      cta_text: "Go to Job Sources", cta_path: job_sources_path %>
<% end %>
