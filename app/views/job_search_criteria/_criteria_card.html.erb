<div class="card source-card">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <h5 class="source-card__name mb-0"><%= criteria.name %></h5>
      <% if criteria.is_default? %>
        <span class="badge bg-primary">Default</span>
      <% end %>
    </div>

    <% if criteria.summary.present? %>
      <p class="text-muted small mb-3"><%= criteria.summary %></p>
    <% end %>

    <div class="source-card__details mb-3">
      <% if criteria.keywords.present? %>
        <div class="small"><strong>Keywords:</strong> <%= criteria.keywords %></div>
      <% end %>
      <% if criteria.location.present? %>
        <div class="small"><strong>Location:</strong> <%= criteria.location %></div>
      <% end %>
      <% if criteria.excluded_companies.present? %>
        <div class="small text-muted"><strong>Excluded:</strong> <%= criteria.excluded_companies %></div>
      <% end %>
    </div>

    <div class="d-flex gap-2">
      <% unless criteria.is_default? %>
        <%= button_to "Set Default", set_default_job_search_criterium_path(criteria), method: :patch,
            class: "btn btn-sm btn-outline-primary" %>
      <% end %>
      <%= link_to "Edit", edit_job_search_criterium_path(criteria), class: "btn btn-sm btn-outline-primary" %>
      <%= button_to "Remove", job_search_criterium_path(criteria), method: :delete,
          class: "btn btn-sm btn-outline-danger",
          data: { turbo_confirm: "Remove '#{criteria.name}'?" } %>
    </div>
  </div>
</div>
