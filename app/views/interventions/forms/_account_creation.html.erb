<p class="text-muted mb-3">An account needs to be created on this platform before we can proceed. Please create one manually, then confirm below.</p>
<div class="form-check mb-3">
  <input type="checkbox" name="user_input[account_created]" value="true" class="form-check-input" id="user_input_account_created" required>
  <label class="form-check-label" for="user_input_account_created">I have created an account on this platform</label>
</div>
<div class="row g-3">
  <div class="col-md-6">
    <label for="user_input_username" class="form-label fw-bold">Username / Email (optional)</label>
    <input type="text" name="user_input[username]" id="user_input_username" class="form-control" placeholder="your@email.com">
  </div>
  <div class="col-md-6">
    <label for="user_input_password" class="form-label fw-bold">Password (optional)</label>
    <input type="password" name="user_input[password]" id="user_input_password" class="form-control" placeholder="Password">
  </div>
</div>
