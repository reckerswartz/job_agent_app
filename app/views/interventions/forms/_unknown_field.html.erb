<p class="text-muted mb-3">The automation encountered a form field it doesn't know how to fill. Please provide the value below.</p>
<div class="mb-3">
  <label for="user_input_field_value" class="form-label fw-bold">Field Value</label>
  <input type="text" name="user_input[field_value]" id="user_input_field_value" class="form-control" placeholder="Enter the value for this field" required>
</div>
<div class="mb-3">
  <label for="user_input_notes" class="form-label fw-bold">Notes (optional)</label>
  <textarea name="user_input[notes]" id="user_input_notes" class="form-control" rows="2" placeholder="Any additional context"></textarea>
</div>
