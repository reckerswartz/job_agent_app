<p class="text-muted mb-3">Enter the credentials needed to log in to this platform.</p>
<div class="row g-3">
  <div class="col-md-6">
    <label for="user_input_username" class="form-label fw-bold">Username / Email</label>
    <input type="text" name="user_input[username]" id="user_input_username" class="form-control" placeholder="your@email.com" required>
  </div>
  <div class="col-md-6">
    <label for="user_input_password" class="form-label fw-bold">Password</label>
    <input type="password" name="user_input[password]" id="user_input_password" class="form-control" placeholder="Password" required>
  </div>
</div>
