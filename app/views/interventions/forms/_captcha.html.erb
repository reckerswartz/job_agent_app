<p class="text-muted mb-3">A CAPTCHA was encountered. Please solve it manually in the browser, then confirm below.</p>
<div class="mb-3">
  <label for="user_input_captcha_answer" class="form-label fw-bold">CAPTCHA Answer</label>
  <input type="text" name="user_input[captcha_answer]" id="user_input_captcha_answer" class="form-control" placeholder="Enter the CAPTCHA text">
</div>
<div class="form-check mb-3">
  <input type="checkbox" name="user_input[manually_solved]" value="true" class="form-check-input" id="user_input_manually_solved">
  <label class="form-check-label" for="user_input_manually_solved">I solved the CAPTCHA manually in the browser</label>
</div>
