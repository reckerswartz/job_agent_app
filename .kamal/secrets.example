# Kamal deployment secrets
# Copy this file to .kamal/secrets and fill in your values
# NEVER commit the actual secrets file

KAMAL_REGISTRY_PASSWORD=your_ghcr_token_here
RAILS_MASTER_KEY=your_master_key_from_config_master_key
POSTGRES_PASSWORD=your_secure_database_password
NVIDIA_API_KEY=your_nvidia_api_key_here
